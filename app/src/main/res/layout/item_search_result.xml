<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="?android:attr/selectableItemBackground"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/imageCover"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="centerCrop"
        android:background="#f0f0f0"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/textTrackTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Название трека"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/textArtistName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Исполнитель"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textAlbumName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Альбом"
                android:textSize="12sp"
                android:textColor="#666"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/textDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3:30"
                android:textSize="12sp"
                android:textColor="#666"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/buttonAdd"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_heart_outline"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Добавить в коллекцию"
        android:visibility="visible"/>

    <ImageButton
        android:id="@+id/badgeInCollection"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_heart_filled"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Уже в коллекции"
        android:visibility="gone"/>

</LinearLayout>